#pragma once
#include <pgmspace.h>

// Copia este archivo a secrets.h y rellena con tus credenciales AWS IoT Core.
// Instrucciones: https://docs.aws.amazon.com/iot/latest/developerguide/create-iot-resources.html

#define THINGNAME        "esp32-cardio-01"          // Nombre del Thing en AWS IoT
#define AWS_IOT_ENDPOINT "XXXXXX-ats.iot.us-east-1.amazonaws.com"  // Settings > Device data endpoint

// Amazon Root CA 1 — descargar de:
// https://www.amazontrust.com/repository/AmazonRootCA1.pem
static const char AWS_CERT_CA[] PROGMEM = R"EOF(
-----BEGIN CERTIFICATE-----
<pega aqui el contenido de AmazonRootCA1.pem>
-----END CERTIFICATE-----
)EOF";

// Device Certificate — generado al crear el Thing en AWS IoT Console
static const char AWS_CERT_CRT[] PROGMEM = R"EOF(
-----BEGIN CERTIFICATE-----
<pega aqui el contenido de xxxxx-certificate.pem.crt>
-----END CERTIFICATE-----
)EOF";

// Device Private Key — generado al crear el Thing en AWS IoT Console
static const char AWS_CERT_PRIVATE[] PROGMEM = R"EOF(
-----BEGIN RSA PRIVATE KEY-----
<pega aqui el contenido de xxxxx-private.pem.key>
-----END RSA PRIVATE KEY-----
)EOF";
